# Firebase public client
NEXT_PUBLIC_FIREBASE_API_KEY=demo-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=summa-board.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=summa-board
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=summa-board.firebasestorage.app
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000:web:summa-board
NEXT_PUBLIC_USE_EMULATORS=true

# Firebase server
FIREBASE_PROJECT_ID=summa-board
FIREBASE_STORAGE_BUCKET=summa-board.firebasestorage.app

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com

# Hosting
CANONICAL_HOST=summa-board.app
FORCE_CANONICAL_REDIRECT=false

# Monitoring (Telegram)
TELEGRAM_ALERTS_ENABLED=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=68198321
