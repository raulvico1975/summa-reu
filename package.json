{
  "name": "summa-board",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1 --port 3000",
    "dev:preview": "next dev --hostname localhost --port 3001",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "i18n:check-es": "node scripts/i18n/check-es-coverage.mjs",
    "ci:smoke": "bash scripts/ci-smoke.sh",
    "emu": "PATH=/opt/homebrew/opt/openjdk/bin:$PATH firebase emulators:exec --project summa-board --only auth,firestore,storage,ui \"NEXT_PUBLIC_USE_EMULATORS=true NEXT_PUBLIC_FIREBASE_PROJECT_ID=summa-board NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=summa-board.firebasestorage.app FIREBASE_PROJECT_ID=summa-board FIREBASE_STORAGE_BUCKET=summa-board.firebasestorage.app next dev --hostname 127.0.0.1 --port 3000\"",
    "seed": "FIRESTORE_EMULATOR_HOST=127.0.0.1:8085 FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099 FIREBASE_STORAGE_EMULATOR_HOST=127.0.0.1:9199 FIREBASE_PROJECT_ID=summa-board FIREBASE_STORAGE_BUCKET=summa-board.firebasestorage.app node scripts/seed.mjs",
    "test:smoke": "node scripts/smoke.mjs",
    "test:permissions": "node scripts/check-firebase-permissions.mjs",
    "test:telegram": "node scripts/test-telegram-alert.mjs",
    "monitor:login": "node scripts/monitor-login.mjs --watch",
    "bootstrap:firebase": "bash scripts/bootstrap-firebase.sh"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "firebase": "^12.10.0",
    "firebase-admin": "^13.7.0",
    "next": "^15.5.12",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^15.5.12",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
